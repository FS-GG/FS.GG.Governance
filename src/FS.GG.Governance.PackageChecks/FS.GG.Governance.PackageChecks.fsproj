<Project Sdk="Microsoft.NET.Sdk">

  <!-- F24 (P1): the PACKAGE/API deterministic check pack — `.fsi` baseline drift + published FSI transcript
       currency. Bundles three modules in the F054 ReleaseFactsSensing shape: `Model` (the closed package
       fact vocabulary), `PackageChecks.evaluate` (PURE/TOTAL — no I/O), and `Interpreter` (the SOLE
       filesystem/process seam: reads the `.fsi` surface + runs the published transcripts by shelling FSI
       through the injected F051/F052 GateExecution `ExecutionPort` — no FSharp.Compiler.Service).
       References ONLY SurfaceChecks (the shared SurfaceFinding shape), Config, and GateExecution
       (the transcript execution port). No cross-domain reference (FR-008). No new third-party package. -->
  <PropertyGroup>
    <RootNamespace>FS.GG.Governance.PackageChecks</RootNamespace>
    <Version>0.1.0</Version>
    <IsPackable>true</IsPackable>
    <PackageId>FS.GG.Governance.PackageChecks</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Model.fsi" />
    <Compile Include="Model.fs" />
    <Compile Include="PackageChecks.fsi" />
    <Compile Include="PackageChecks.fs" />
    <Compile Include="Interpreter.fsi" />
    <Compile Include="Interpreter.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../FS.GG.Governance.SurfaceChecks/FS.GG.Governance.SurfaceChecks.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.GateExecution/FS.GG.Governance.GateExecution.fsproj" />
  </ItemGroup>

</Project>

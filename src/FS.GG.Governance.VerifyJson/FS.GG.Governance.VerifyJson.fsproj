<Project Sdk="Microsoft.NET.Sdk">

  <!-- F056: the optional, packable verify.json *projection* â€” the verify.json document row. A single pure,
       total `VerifyJson.ofVerifyDecision : ShipDecision -> CacheEligibilityReport option ->
       (GateId * GateOutcome) list -> string` (plus a `schemaVersion` constant) renders the F024
       `ShipDecision` (rolled at `RunMode.Verify`) plus the F041 `CacheEligibilityReport` and the F052 per-gate
       execution outcomes into the deterministic, versioned `verify.json` WHOLE-CHANGE pre-PR verification
       document text â€” the stable, machine-readable per-change verification contract a pre-PR CI step,
       dashboards, agents, and generated readiness views read instead of an in-memory value.

       Sibling of F025 `AuditJson` (the whole-change ship verdict) and F042 `CacheEligibilityJson` (the
       per-change cache verdict): this projects the WHOLE-CHANGE verify verdict plus a first-class `currency`
       section (fresh/reused, recomputed, unresolved). It is emit-only: it re-derives/re-classifies/re-sorts
       NOTHING (the `ShipDecision` fixed the verdict/basis/partition, the `CacheEligibilityReport` fixed each
       per-gate verdict, the execution list fixed each per-gate disposition). It never dereferences the opaque
       evidence reference, maps no numeric exit code, and emits no host path/timestamp/username/environment
       value (FR-007/FR-008). PURE and TOTAL: no I/O, no git, no clock, never throws.

       It references the cores whose public types appear in `ofVerifyDecision`'s signature â€” Ship (F024,
       ShipDecision), Enforcement (F023, the enforcement vocabulary), CacheEligibility (F041,
       CacheEligibilityReport), GateRun (F052, GateOutcome), EvidenceReuse (F030, EvidenceRef) â€” plus the
       transitive Config/Gates/Findings/FreshnessKey identity renderers. It adds NO new third-party
       PackageReference â€” serialization is the net10.0 shared-framework `System.Text.Json` (`Utf8JsonWriter`)
       the kernel's `Json.fs` and F020/F021/F025/F042/F055's projections already use, so the library stays
       System.*/FSharp.Core-only (FR-014). No YamlDotNet, no AuditJson ref. Compile order is VerifyJson.fsi ->
       VerifyJson.fs: the curated public surface, then the pure projection. The whole surface is a pure total
       function â€” no MVU ceremony (Principle IV). -->
  <PropertyGroup>
    <RootNamespace>FS.GG.Governance.VerifyJson</RootNamespace>
    <Version>0.1.0</Version>
    <IsPackable>true</IsPackable>
    <PackageId>FS.GG.Governance.VerifyJson</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <!-- 076 Phase C: the four projection seam modules, compiled BEFORE the thin VerifyJson entry. Core is
         FIRST (the entry + the byte order depend on its verdict body). -->
    <Compile Include="Core.fsi" />
    <Compile Include="Core.fs" />
    <Compile Include="SurfaceChecks.fsi" />
    <Compile Include="SurfaceChecks.fs" />
    <Compile Include="ReleaseReadiness.fsi" />
    <Compile Include="ReleaseReadiness.fs" />
    <Compile Include="GeneratedViews.fsi" />
    <Compile Include="GeneratedViews.fs" />
    <Compile Include="VerifyJson.fsi" />
    <Compile Include="VerifyJson.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <!-- F24: the shared SurfaceFinding shape for the additive `surfaceChecks` section. -->
    <ProjectReference Include="../FS.GG.Governance.SurfaceChecks/FS.GG.Governance.SurfaceChecks.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.CacheEligibility/FS.GG.Governance.CacheEligibility.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.GateRun/FS.GG.Governance.GateRun.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <!-- F26: the advisory releaseReadiness preview projects the ReleaseReport single source of truth. -->
    <ProjectReference Include="../FS.GG.Governance.ReleaseReport/FS.GG.Governance.ReleaseReport.fsproj" />
    <ProjectReference Include="..\FS.GG.Governance.RuleIdentity\FS.GG.Governance.RuleIdentity.fsproj" />
    <!-- F070: the stale-generated-view `generatedViews` overload references the pure CurrencyEnforcement
         leaf (CurrencyFinding, the overload's signature type; categoryToken in Core arrives transitively). -->
    <ProjectReference Include="../FS.GG.Governance.CurrencyEnforcement/FS.GG.Governance.CurrencyEnforcement.fsproj" />
    <!-- JSON-4: the `generatedViews` array writer body (was byte-identical to AuditJson's copy) now lives
         ONCE in the shared GeneratedViewsJson leaf; the `GeneratedViews` seam delegates to it (RefreshJson's
         RefreshModel.viewKindToken arrives transitively through that leaf). -->
    <ProjectReference Include="../FS.GG.Governance.GeneratedViewsJson/FS.GG.Governance.GeneratedViewsJson.fsproj" />
  </ItemGroup>


  <ItemGroup>
    <!-- 073: the shared deterministic-emit helper JsonText.writeToString (pure System.Text.Json leaf;
         NOT the kernel â€” the pure projections must not reference the kernel/host capability). -->
    <ProjectReference Include="../FS.GG.Governance.JsonText/FS.GG.Governance.JsonText.fsproj" />
  </ItemGroup>


  <ItemGroup>
    <!-- 073: the shared closed-enum token helpers (pure JsonTokens leaf; module-qualified calls). -->
    <ProjectReference Include="../FS.GG.Governance.JsonTokens/FS.GG.Governance.JsonTokens.fsproj" />
  </ItemGroup>


  <ItemGroup>
    <!-- 073: the shared sub-object/map writers (pure JsonWriters leaf; module-qualified calls). -->
    <ProjectReference Include="../FS.GG.Governance.JsonWriters/FS.GG.Governance.JsonWriters.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.AttestationJson/FS.GG.Governance.AttestationJson.fsproj" />
  </ItemGroup>

</Project>

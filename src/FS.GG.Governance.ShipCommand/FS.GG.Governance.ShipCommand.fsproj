<Project Sdk="Microsoft.NET.Sdk">

  <!-- F026 host edge: the SECOND composition/edge tier — the `fsgg ship` protected-branch verdict.
       It is the host sibling of F022 `RouteCommand`: where `route` SHOWED the selected gates and always
       exited 0, `ship` rolls the same routed change up into a pass/fail MERGE VERDICT under a chosen
       mode/profile, writes the `audit.json` a protected branch reads, and exits with a numeric code CI
       can block on (the new `Blocked` exit category).

       It reuses VERBATIM, via project references, the SIX F022 cores it composes (Config F014,
       Routing F015, Snapshot F016, Findings F017, Gates F018, Route F019 — NOT RouteJson/GatesJson,
       which `ship` does not project) PLUS the three Phase-5/projection cores this row newly composes:
       Enforcement (F023, lever parsers + RunMode/Profile), Ship (F024, rollup + ShipDecision), and
       AuditJson (F025, ofShipDecision). It adds NO new third-party dependency: git sensing is delegated
       to Snapshot, catalog reads to Config, enforcement/rollup to Enforcement/Ship, serialization to
       AuditJson; the only new impure primitives are a `System.IO` write (the ArtifactWriter port) and
       `Environment.Exit` at the Program edge — both BCL.

       Modeled through an Elmish/MVU boundary (Principle IV, load-bearing): a PURE `Loop`
       (parse/init/update/render/exitCode over Model/Msg/Effect, including the ExitCodeBasis -> exit
       mapping) + an EDGE `Interpreter` (injected, fakeable Ports; realPorts/step/run) + a thin Program.
       Compile order Loop -> Interpreter -> Program.

       IsPackable=false this slice: the single-packed-`fsgg`-tool unification (one tool dispatching the
       `route` and `ship` verbs) is an explicitly deferred follow-up (research D1), so this row does NOT
       ship a second NuGet tool that also claims the `fsgg` ToolCommandName F022 already owns. -->
  <PropertyGroup>
    <RootNamespace>FS.GG.Governance.ShipCommand</RootNamespace>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Loop.fsi" />
    <Compile Include="Loop.fs" />
    <Compile Include="Interpreter.fsi" />
    <Compile Include="Interpreter.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Snapshot/FS.GG.Governance.Snapshot.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Routing/FS.GG.Governance.Routing.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.AuditJson/FS.GG.Governance.AuditJson.fsproj" />
    <!-- F27 wiring (063): the plain human projection over the SAME ShipDecision the audit.json path serializes -->
    <ProjectReference Include="../FS.GG.Governance.HumanText/FS.GG.Governance.HumanText.fsproj" />
    <!-- F27 wiring (063): the rich render + capability sensing at the edge (Spectre stays confined here) -->
    <ProjectReference Include="../FS.GG.Governance.HumanRender/FS.GG.Governance.HumanRender.fsproj" />
    <!-- F046: the cache-eligibility pipeline (sense → resolve → evaluate → embed Some report) -->
    <ProjectReference Include="../FS.GG.Governance.FreshnessSensing/FS.GG.Governance.FreshnessSensing.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.CacheEligibility/FS.GG.Governance.CacheEligibility.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.FreshnessResolution/FS.GG.Governance.FreshnessResolution.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
    <!-- F048: the pure write half of the evidence-reuse store (prune/retain/serialise) -->
    <ProjectReference Include="../FS.GG.Governance.EvidenceReuseStore/FS.GG.Governance.EvidenceReuseStore.fsproj" />
    <!-- F052: run each selected must-recompute command-gate (GateExecution port), derive its evidence
         (EvidenceCapture), and compose the shared pure helpers + GateOutcome vocabulary (GateRun). -->
    <ProjectReference Include="../FS.GG.Governance.GateRun/FS.GG.Governance.GateRun.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.GateExecution/FS.GG.Governance.GateExecution.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.EvidenceCapture/FS.GG.Governance.EvidenceCapture.fsproj" />
    <!-- F25 host wiring (064): the four already-built cost-cache/provenance cores consumed VERBATIM at the
         MVU interpreter edge (budget filter, kinded-run recording, the two deterministic sidecars), plus
         F033 Provenance for the audit snapshot's BuilderIdentity/Provenance build. No new external dep. -->
    <ProjectReference Include="../FS.GG.Governance.CostBudget/FS.GG.Governance.CostBudget.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.CommandKind/FS.GG.Governance.CommandKind.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.CostBudgetJson/FS.GG.Governance.CostBudgetJson.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.ProvenanceJson/FS.GG.Governance.ProvenanceJson.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Provenance/FS.GG.Governance.Provenance.fsproj" />
  </ItemGroup>

</Project>

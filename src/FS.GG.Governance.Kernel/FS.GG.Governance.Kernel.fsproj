<Project Sdk="Microsoft.NET.Sdk">

  <!-- F01 kernel: pure, BCL-only reasoner. NO PackageReference of any kind
       (FR-010, SC-005). FSharp.Core is supplied implicitly by the SDK and pinned
       centrally. Does NOT pack (D7) — IsPackable=false inherited from
       Directory.Build.props. -->
  <PropertyGroup>
    <RootNamespace>FS.GG.Governance.Kernel</RootNamespace>
    <Version>0.1.1</Version>
    <!-- M1 exit (F06 T024): the kernel is now the first useful product, so it packs
         (overrides IsPackable=false from Directory.Build.props). The test project stays
         non-packable. Packaging metadata only — no .fsi, no behaviour, no new dependency. -->
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Verdict (F02): a pure value algebra with zero dependency on the F01 fact/rule
         types, so it compiles BEFORE Kernel.* (dependency-free first). -->
    <Compile Include="Verdict.fsi" />
    <Compile Include="Verdict.fs" />
    <Compile Include="Kernel.fsi" />
    <Compile Include="Kernel.fs" />
    <!-- Evidence (F05): the six-case EvidenceState, the abstract cycle-rejecting
         EvidenceGraph<'id>, and the transitive synthetic-taint closure (effective).
         A pure derivation over DECLARED states — no I/O, zero new dependency (only
         Map/Set). Its only real predecessor is the F01 core's least-fixed-point
         discipline; it references none of Verdict/Check/CheckRule, and Check.*/
         CheckRule.* do not depend on it — so it compiles right after Kernel.*,
         documenting that relationship in the build order (plan Structure Decision). -->
    <Compile Include="Evidence.fsi" />
    <Compile Include="Evidence.fs" />
    <!-- Check (F03): the reified Check algebra + six interpreters. Depends on both
         Verdict (the verdict it folds to) and Kernel.FactSet<'fact> (the facts a
         probe's Eval consumes), so it compiles AFTER both. -->
    <Compile Include="Check.fsi" />
    <Compile Include="Check.fs" />
    <!-- CheckRule (F04): the CheckTier arbitration model + the Rule bridge. Depends on
         Check (the algebra it bridges/folds), Verdict (the verdict a RuleOutcome carries),
         and Kernel (the Rule<'fact>/FactSet/ProvenanceStep it emits into), so it compiles
         LAST. SHA-256 only — no new dependency (FR-016, SC-009). -->
    <Compile Include="CheckRule.fsi" />
    <Compile Include="CheckRule.fs" />
    <!-- F06 output layer: the three derivations that turn the kernel's in-memory reasoning
         into portable data and complete Milestone M1. Compiled AFTER CheckRule.* in the
         order Freshness → Contract → Json (Json LAST): Contract references F04
         CheckRule/Severity/SpecSource + F03 Check.render; Json references F03 Explanation,
         F05 EvidenceState, and F06 ContractEntry. JSON via the shared-framework
         System.Text.Json — zero new dependency (plan Structure Decision, data-model §6). -->
    <Compile Include="Freshness.fsi" />
    <Compile Include="Freshness.fs" />
    <Compile Include="Contract.fsi" />
    <Compile Include="Contract.fs" />
    <Compile Include="Json.fsi" />
    <Compile Include="Json.fs" />
    <!-- Route (F07): the light routing layer — stakes & fences (forbid-trumps-permit,
         never positional), run modes, and the explainable Route. Compiled AFTER
         Contract.* (it reuses F06 ContractEntry/Contract.ofRules → F04 CheckRule/
         Severity → F03 Check.render → F02 Verdict, and F01 RuleId). Route and Json are
         independent, so Route.* is appended after Json.* (append-only). Starts M2.
         Standard library only — zero new dependency (FR-017, SC-011). -->
    <Compile Include="Route.fsi" />
    <Compile Include="Route.fs" />
  </ItemGroup>

</Project>

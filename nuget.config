<?xml version="1.0" encoding="utf-8"?>
<!-- nuget.config (repo root) — adds the org GitHub Packages NuGet feed ADDITIVELY; does NOT
     <clear/> inherited sources, so nuget.org still resolves the public packages (YamlDotNet,
     Expecto, …). Most FS.GG.* packages (e.g. FS.GG.Contracts — consumed by FS.GG.Governance.Config
     per FS-GG/.github#16 / FS.GG.Governance#14) are published to the private org feed, NOT nuget.org.
     FS.GG.Coord.Cli is the exception: it is dual-published anonymously to nuget.org (FS-GG/.github#624,
     ADR-0034 Phase 3a) so no credential is needed to run scripts/fsgg-coord — see the mapping below.
     Credentials are env placeholders (NO secret is committed): locally export FSGG_PACKAGES_ACTOR +
     FSGG_PACKAGES_READ_TOKEN (a PAT with read:packages); in CI they are wired from GITHUB_TOKEN with
     `permissions: packages: read` (see .github/workflows/gate.yml). -->
<configuration>
  <packageSources>
    <add key="fsgg-github" value="https://nuget.pkg.github.com/FS-GG/index.json" protocolVersion="3" />
  </packageSources>
  <!-- CPM with >1 source requires explicit source mapping (NU1507): FS.GG.* resolve from the
       private org feed; everything else from the inherited public nuget.org. NuGet resolves a
       package against its LONGEST matching pattern, so the exact id FS.GG.Coord.Cli below beats
       the FS.GG.* prefix and routes to nuget.org alone (FS.GG.Governance#243). Scoped to the exact
       id deliberately: mapping the whole FS.GG.* prefix to nuget.org would change resolution for
       every other FS.GG package. The FS.GG. prefix is reserved on nuget.org for the publishing
       account (ADR-0012 §5 anti-squat control, granted 2026-07-17). -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="FS.GG.Coord.Cli" />
    </packageSource>
    <packageSource key="fsgg-github">
      <package pattern="FS.GG.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <fsgg-github>
      <add key="Username" value="%FSGG_PACKAGES_ACTOR%" />
      <add key="ClearTextPassword" value="%FSGG_PACKAGES_READ_TOKEN%" />
    </fsgg-github>
  </packageSourceCredentials>
</configuration>

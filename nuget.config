<?xml version="1.0" encoding="utf-8"?>
<!-- nuget.config (repo root) — adds the org GitHub Packages NuGet feed ADDITIVELY; does NOT
     <clear/> inherited sources, so nuget.org still resolves the public packages (YamlDotNet,
     Expecto, …). The FS.GG.* packages (e.g. FS.GG.Contracts — consumed by FS.GG.Governance.Config
     per FS-GG/.github#16 / FS.GG.Governance#14) are published to the private org feed, NOT nuget.org.
     Credentials are env placeholders (NO secret is committed): locally export FSGG_PACKAGES_ACTOR +
     FSGG_PACKAGES_READ_TOKEN (a PAT with read:packages); in CI they are wired from GITHUB_TOKEN with
     `permissions: packages: read` (see .github/workflows/gate.yml). -->
<configuration>
  <packageSources>
    <add key="fsgg-github" value="https://nuget.pkg.github.com/FS-GG/index.json" protocolVersion="3" />
  </packageSources>
  <!-- CPM with >1 source requires explicit source mapping (NU1507): FS.GG.* resolve from the
       private org feed; everything else from the inherited public nuget.org. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="fsgg-github">
      <package pattern="FS.GG.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <fsgg-github>
      <add key="Username" value="%FSGG_PACKAGES_ACTOR%" />
      <add key="ClearTextPassword" value="%FSGG_PACKAGES_READ_TOKEN%" />
    </fsgg-github>
  </packageSourceCredentials>
</configuration>

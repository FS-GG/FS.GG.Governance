<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F042, exercising the PUBLIC surface of FS.GG.Governance.CacheEligibilityJson:
       `CacheEligibilityJson.ofReport` / `schemaVersion` over REAL upstream-assembled inputs — a real
       `CacheEligibilityReport` from the genuine F041 `CacheEligibility.evaluate` over real candidate gates
       (real F018 `GateId`, real F029 `FreshnessInputs`) against a real F030 `ReuseStore` assembled via
       `EvidenceReuse.record` (the genuine value a downstream route/audit/CI/agent caller holds) — never mocks,
       never private writer helpers (Principle V). The EMITTED BYTES are inspected by a read-only
       `System.Text.Json.JsonDocument` parse, exactly as the kernel's `Json` tests and F020/F021/F025's
       `RouteJson`/`GatesJson`/`AuditJson` tests do. Driving the real `evaluate` re-exercises the F041
       roll-up, catching any projection-time mismatch a mock would hide. Expecto + FsCheck give the
       determinism + order-independence + no-hide + totality properties; the VSTest adapters let `dotnet test`
       drive the Expecto runner. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="ProjectionTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="NoHideTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="ExclusionsTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibilityJson/FS.GG.Governance.CacheEligibilityJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibility/FS.GG.Governance.CacheEligibility.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
  </ItemGroup>

</Project>

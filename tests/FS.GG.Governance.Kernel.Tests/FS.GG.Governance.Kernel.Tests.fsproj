<Project Sdk="Microsoft.NET.Sdk">

  <!-- Test-only project. Exercises the kernel through its PUBLIC surface
       (the ProjectReference resolves the built library — SC-004). Expecto + FsCheck
       give the order-independence property; the VSTest adapters let `dotnet test`
       drive the Expecto runner. None of these deps reach the kernel assembly. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="FixedPointTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="VerdictTests.fs" />
    <Compile Include="CheckTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Kernel/FS.GG.Governance.Kernel.fsproj" />
  </ItemGroup>

</Project>

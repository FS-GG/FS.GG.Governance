<Project Sdk="Microsoft.NET.Sdk">

  <!-- Test-only project. Exercises the Spec Kit adapter through its PUBLIC surface (the
       ProjectReference resolves the built library — Principle I, SC-008). Expecto +
       FsCheck give the phase-guard properties (SC-002) and order-independence. None of
       these deps reach the adapter assembly. The SECOND composition domain it authors is
       SYNTHETIC (Principle V); the Spec Kit adapter itself is the real adopter under test. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ExampleAdapters.fs" />
    <Compile Include="SpecKitTests.fs" />
    <Compile Include="CatalogTests.fs" />
    <Compile Include="ReviewedArtifactsTests.fs" />
    <Compile Include="LiftTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Adapters.SpecKit/FS.GG.Governance.Adapters.SpecKit.fsproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F029, exercising the PUBLIC surface of FS.GG.Governance.FreshnessKey:
       `FreshnessKey.compute` / `matches` / `diff` / `value` and `Model.categoryToken` over REAL,
       literally-constructible `FreshnessInputs` values (Principle V — every value is a real typed value,
       never a mock; the operations are pure so no upstream chain is needed). The EMITTED key bytes are
       inspected by ordinary string comparison and a small committed golden table. Expecto + FsCheck give
       the determinism / order-and-duplication-invariance / injectivity / totality properties; the VSTest
       adapters let `dotnet test` drive the Expecto runner. The reflective SurfaceDrift test pins the
       Tier-1 public surface + the Config/BCL/FSharp.Core-only scope guard (plan D1). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="DistinctionTests.fs" />
    <Compile Include="InjectivityTests.fs" />
    <Compile Include="InspectionTests.fs" />
    <Compile Include="PurityTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
  </ItemGroup>

</Project>

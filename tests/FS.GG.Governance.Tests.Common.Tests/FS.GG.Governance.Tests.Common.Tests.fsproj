<Project Sdk="Microsoft.NET.Sdk">

  <!-- 074: the additive test harness for the shared support library. It pins the library's public
       surface (reflective SurfaceBaselineTests vs surface/FS.GG.Governance.Tests.Common.surface.txt,
       blessed via BLESS_SURFACE=1), enforces FR-008 with a scope-guard test (no src/*.fsproj references
       the library), and smoke-tests RepositoryHelpers/CatalogFixtures directly for real-evidence
       coverage independent of the migrated suites. This is the ONLY additive test-count increase the
       feature introduces (research D3). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="SurfaceBaselineTests.fs" />
    <Compile Include="SmokeTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
  </ItemGroup>

</Project>

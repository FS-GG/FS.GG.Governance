<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F024, exercising the PUBLIC surface of FS.GG.Governance.Ship: `Ship.rollup`
       and the `Ship.Model` result vocabulary over REAL typed values — real F018 `Gate`s, F017
       `UnknownGovernedPathFinding`s, F019 `RouteResult`s, and the F023 `RunMode`/`Profile` levers —
       never private helpers (the hidden gate/finding -> `EnforcementInput` mappings, the
       item-identity builder, and the `itemSortKey` helper are tested ONLY through `rollup`) and never
       mocks (Principle V). The per-item input domain is the finite cross-product of gate maturity /
       finding zone × run mode × profile, all literally constructible, so NO synthetic evidence is
       anticipated. Expecto + FsCheck give the totality/determinism/carry/partition properties; the
       VSTest adapters let `dotnet test` drive the Expecto runner. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="RollupTests.fs" />
    <Compile Include="WorkedExampleTests.fs" />
    <Compile Include="CarryTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
  </ItemGroup>

</Project>

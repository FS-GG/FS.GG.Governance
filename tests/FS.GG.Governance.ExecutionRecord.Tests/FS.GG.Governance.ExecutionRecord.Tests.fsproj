<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F050, exercising the PUBLIC surface of FS.GG.Governance.ExecutionRecord:
       `digestOf` / `recordOf` over REAL byte buffers and REAL F032 run facts. The output digests under test
       are DERIVED from real byte buffers (`digestOf realBytes`), never `Synthetic` literals — that is the
       whole point of this row: it removes the last synthetic-evidence stand-in on the capture path (F049 could
       only derive references from hand-written digests; now the digests are real). `recordOf` is exercised
       against the genuine `CommandRecord.build`/`canonicalId`; the close-the-loop tests drive the REAL F049
       `EvidenceCapture.referenceOf`/`capture` and F030 `EvidenceReuse.decide`/`empty` over real F029
       `FreshnessInputs`. No filesystem/clock/process/network anywhere (SC-008) except the repo-root walk the
       surface baseline path uses.

       EvidenceCapture (F049), EvidenceReuse (F030), and FreshnessKey (F029) appear here as TEST-ONLY
       ProjectReferences (for the close-the-loop round-trip only); the production library has NO such
       dependency (plan "Dependency direction" / the scope-hygiene assertion). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="DigestTests.fs" />
    <Compile Include="RecordTests.fs" />
    <Compile Include="CloseLoopTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.ExecutionRecord/FS.GG.Governance.ExecutionRecord.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CommandRecord/FS.GG.Governance.CommandRecord.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceCapture/FS.GG.Governance.EvidenceCapture.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
  </ItemGroup>

</Project>

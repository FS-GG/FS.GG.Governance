<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F032, exercising the PUBLIC surface of FS.GG.Governance.CommandRecord:
       `CommandRecord.build` / `canonicalId` / `identityValue` over REAL, literally-constructible run facts
       (Principle V — every value is a real typed value built from literals, never a mock; no process is
       spawned). The EMITTED identity bytes are inspected by ordinary string comparison and the committed
       worked-example block. Expecto + FsCheck give the carriage / sensed-split / per-field-sensitivity /
       env-delta order-and-duplication-invariance / argument-order-significance / determinism / purity /
       totality properties; the VSTest adapters let `dotnet test` drive the Expecto runner. The reflective
       SurfaceDrift test pins the Tier-1 public surface + the Config/BCL/FSharp.Core-only scope guard
       (plan D1). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="RecordTests.fs" />
    <Compile Include="IdentityTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="PurityTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.CommandRecord/FS.GG.Governance.CommandRecord.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
  </ItemGroup>

</Project>

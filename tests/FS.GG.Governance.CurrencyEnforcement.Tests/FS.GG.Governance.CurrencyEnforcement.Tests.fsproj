<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for the pure F070 leaf (FS.GG.Governance.CurrencyEnforcement): decideCurrency reproduces
       the F057 per-view outcomes over the REAL F029 FreshnessKey comparator (never mocked); the findingsOf
       opt-in gate; the truth-table sweep proving 0 new branches against the REAL F023 Enforcement core; the
       no-hide totality; the C1/FR-009 verify-boundary profile evidence; and the leaf surface-drift baseline. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="DecideCurrencyTests.fs" />
    <Compile Include="FindingsGateTests.fs" />
    <Compile Include="EnforcementSweepTests.fs" />
    <Compile Include="NoHideTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.CurrencyEnforcement/FS.GG.Governance.CurrencyEnforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.RefreshJson/FS.GG.Governance.RefreshJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <!-- 101 (M-CI-3): the shared SurfaceDrift helper for the consolidated surface-drift check. -->
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F039, exercising the PUBLIC surface of FS.GG.Governance.AdvisoryPromotion:
       `AdvisoryPromotion.decide` / `satisfiedBases` / `signOffValue` / `confirmationValue` / `thresholdValue`
       and the `Model` types over REAL, literally-constructible values (Principle V — every value is a genuine
       typed token: a real F030 `EvidenceRef`, literal `ConfirmationCount`/`ConfidenceThreshold`, a literal
       `SignOff`; no mock, no clock read, no model invoked, no file read, no bytes hashed). Expecto + FsCheck
       give the advisory-default / all-named / inclusive-comparator-with-no-single-sample-floor / totality /
       determinism / necessary-not-sufficient / non-empty-eligibility properties; the VSTest adapters let
       `dotnet test` drive the Expecto runner. The reflective SurfaceDrift test pins the Tier-1 public surface +
       the EvidenceReuse(+transitive cores)/BCL/FSharp.Core-only scope guard (plan D1/D3, SC-007). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="AdvisoryDefaultTests.fs" />
    <Compile Include="EligibilityTests.fs" />
    <Compile Include="ConfidenceComparatorTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="NecessaryNotSufficientTests.fs" />
    <Compile Include="NonEmptyEligibilityTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.AdvisoryPromotion/FS.GG.Governance.AdvisoryPromotion.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
  </ItemGroup>

</Project>

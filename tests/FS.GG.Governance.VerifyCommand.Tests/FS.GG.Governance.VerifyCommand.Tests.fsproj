<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F056, exercising the PUBLIC surface of FS.GG.Governance.VerifyCommand: the pure
       `Loop.parse`/`init`/`update`/`render`/`exitCode` driven with literal Model/Msg values (no I/O, no git,
       no clock), and the edge `Interpreter.run`/`step` driven against FAKED ports (an in-memory
       Config.Loader.FileReader, an in-memory Snapshot GitPort over canned raw git output, faked F046 sensing
       ports, a deterministic F051 execution fake, a capturing ArtifactWriter, a capturing OutputSink) — plus
       real-temp-git + real-catalog end-to-end proofs (Principle V). Written bytes are compared against the
       genuine F056 projection (VerifyJson.ofVerifyDecision) of the F024 rollup (Ship.rollup at RunMode.Verify)
       of the same typed inputs, never mocks of the cores. References the cores the VerifyCommand project
       references so tests can construct typed values. Expecto + the VSTest adapters drive `dotnet test`. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="ParseTests.fs" />
    <Compile Include="LoopTests.fs" />
    <Compile Include="EndToEndTests.fs" />
    <Compile Include="CurrencyTests.fs" />
    <Compile Include="ReuseTests.fs" />
    <Compile Include="DegradeTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="PersistenceEdgeTests.fs" />
    <Compile Include="FailureTests.fs" />
    <Compile Include="ScopeGuardTests.fs" />
    <Compile Include="NoMutationTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="HumanTextParityTests.fs" />
    <Compile Include="RenderModeDispatchTests.fs" />
    <Compile Include="CostBudgetWiringTests.fs" />
    <Compile Include="ReleasePreviewTests.fs" />
    <!-- 067 (F24 verify-host wiring): the surface-checks verdict fold + the real-filesystem E2E proofs. -->
    <Compile Include="SurfaceRollupTests.fs" />
    <Compile Include="SurfaceChecksE2ETests.fs" />
    <Compile Include="SeamModuleScopeGuardTests.fs" />
    <Compile Include="HandoffReadinessTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.VerifyCommand/FS.GG.Governance.VerifyCommand.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.VerifyJson/FS.GG.Governance.VerifyJson.fsproj" />
    <!-- F27 wiring (063): the plain human projection asserted at parity with the verify.json contract -->
    <ProjectReference Include="../../src/FS.GG.Governance.HumanText/FS.GG.Governance.HumanText.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Snapshot/FS.GG.Governance.Snapshot.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Routing/FS.GG.Governance.Routing.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <!-- F046: the cache-eligibility pipeline (faked sensing ports + the genuine-core expected-report computer) -->
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessSensing/FS.GG.Governance.FreshnessSensing.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessResolution/FS.GG.Governance.FreshnessResolution.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibility/FS.GG.Governance.CacheEligibility.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuseStore/FS.GG.Governance.EvidenceReuseStore.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessKey/FS.GG.Governance.FreshnessKey.fsproj" />
    <!-- F052: the gate-execution port + capture + outcome vocabulary for the execution scenarios -->
    <ProjectReference Include="../../src/FS.GG.Governance.GateExecution/FS.GG.Governance.GateExecution.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.GateRun/FS.GG.Governance.GateRun.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceCapture/FS.GG.Governance.EvidenceCapture.fsproj" />
    <!-- F25 wiring (064): exercise the consumed cores directly in the budget/sidecar tests. -->
    <ProjectReference Include="../../src/FS.GG.Governance.CostBudget/FS.GG.Governance.CostBudget.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CommandKind/FS.GG.Governance.CommandKind.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CostBudgetJson/FS.GG.Governance.CostBudgetJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ProvenanceJson/FS.GG.Governance.ProvenanceJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Provenance/FS.GG.Governance.Provenance.fsproj" />
    <!-- 065 (US3): the release-preview surfaces the verify tests now construct. -->
    <ProjectReference Include="../../src/FS.GG.Governance.ReleaseRules/FS.GG.Governance.ReleaseRules.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ReleaseFactsSensing/FS.GG.Governance.ReleaseFactsSensing.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.PackEvidence/FS.GG.Governance.PackEvidence.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ReleaseReport/FS.GG.Governance.ReleaseReport.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ValidationMatrix/FS.GG.Governance.ValidationMatrix.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ReleaseDeclaration/FS.GG.Governance.ReleaseDeclaration.fsproj" />
    <!-- 067 (F24 verify-host wiring): name the surface-finding / classification types in the surface tests. -->
    <ProjectReference Include="../../src/FS.GG.Governance.ProductSurfaces/FS.GG.Governance.ProductSurfaces.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.SurfaceChecks/FS.GG.Governance.SurfaceChecks.fsproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F040, exercising the PUBLIC surface of FS.GG.Governance.Calibration:
       `Calibration.decide` / `calibrationReason` / `calibrationMetrics` / `isCalibrated` /
       `observedSampleCount` / `sampleCountValue` / `agreementValue` and the `Model` types over REAL,
       literally-constructible values (Principle V — every value is a genuine typed token: real F035
       `ModelId`/`ModelVersion`/`ReviewerPromptHash`, real F038 `RecordedVerdict`, literal counts/levels; no
       mock, no clock read, no model invoked, no file read, no bytes hashed, no human consulted). Expecto +
       FsCheck give the uncalibrated-by-default / calibrated-with-named-metrics / inclusive-two-threshold-with-
       no-single-sample-floor / totality / determinism / necessary-not-sufficient properties; the VSTest
       adapters let `dotnet test` drive the Expecto runner. The reflective SurfaceDrift test pins the Tier-1
       public surface + the AgentReviewKey/ReviewRecord(+transitive cores)/BCL/FSharp.Core-only scope guard
       (plan D1/D3, SC-007). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="UncalibratedDefaultTests.fs" />
    <Compile Include="CalibratedTests.fs" />
    <Compile Include="ComparatorTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="NecessaryNotSufficientTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Calibration/FS.GG.Governance.Calibration.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.AgentReviewKey/FS.GG.Governance.AgentReviewKey.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.ReviewRecord/FS.GG.Governance.ReviewRecord.fsproj" />
  </ItemGroup>

</Project>

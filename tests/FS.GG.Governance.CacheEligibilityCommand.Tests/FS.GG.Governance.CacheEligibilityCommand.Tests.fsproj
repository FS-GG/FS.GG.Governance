<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F044, exercising the PUBLIC surface of FS.GG.Governance.CacheEligibilityCommand:
       the pure `Loop.parse`/`init`/`update`/`render`/`exitCode` driven with literal Model/Msg values (no
       I/O, no git, no hash, no clock), and the edge `Interpreter.run`/`step` driven against FAKED ports
       (an in-memory Config.Loader.FileReader, an in-memory Snapshot GitPort over canned read-only git
       output, a fake FreshnessSensor with fixed values, an in-memory read-only StoreReader, a capturing
       Write/Out) — plus ONE real-temp-git + real-catalog + real-store end-to-end proof (Principle V).
       Written bytes are compared against the genuine F041/F042/F043 cores of the same typed inputs, never
       mocks of the cores and never private helpers. The fake FreshnessSensor / git are disclosed Synthetic
       (a real hash/git is a non-reproducible oracle); the real path is proven once in the e2e tier. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="ParseTests.fs" />
    <Compile Include="LoopTests.fs" />
    <Compile Include="UnresolvedTests.fs" />
    <Compile Include="SensedEmptyTests.fs" />
    <Compile Include="InterpreterTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="FailureTests.fs" />
    <Compile Include="ExitInformationTests.fs" />
    <Compile Include="StoreFormatTests.fs" />
    <Compile Include="EndToEndTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="HumanTextParityTests.fs" />
    <Compile Include="RenderModeDispatchTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibilityCommand/FS.GG.Governance.CacheEligibilityCommand.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Snapshot/FS.GG.Governance.Snapshot.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Routing/FS.GG.Governance.Routing.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.FreshnessResolution/FS.GG.Governance.FreshnessResolution.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibility/FS.GG.Governance.CacheEligibility.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CacheEligibilityJson/FS.GG.Governance.CacheEligibilityJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.EvidenceReuse/FS.GG.Governance.EvidenceReuse.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.HumanText/FS.GG.Governance.HumanText.fsproj" />
  </ItemGroup>

</Project>

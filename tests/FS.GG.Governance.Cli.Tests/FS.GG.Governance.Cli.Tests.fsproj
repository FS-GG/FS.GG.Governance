<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ParserTests.fs" />
    <Compile Include="MvuTests.fs" />
    <Compile Include="SnapshotTests.fs" />
    <Compile Include="OutputTests.fs" />
    <Compile Include="PackagingTests.fs" />
    <Compile Include="ReadOnlyTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <!-- F27 (P2/P3): the HumanRender edge — rich-over-console / degrade / width, the JSON no-op,
         watch debounce / read-only / safe-failure, and TUI parity / read-only. -->
    <Compile Include="RenderSupport.fs" />
    <Compile Include="RichRenderTests.fs" />
    <Compile Include="DegradeToPlainTests.fs" />
    <Compile Include="WidthResilienceTests.fs" />
    <Compile Include="JsonNoOpTests.fs" />
    <Compile Include="WatchDebounceTests.fs" />
    <Compile Include="WatchReadOnlyTests.fs" />
    <Compile Include="WatchSafeFailureTests.fs" />
    <Compile Include="TuiParityTests.fs" />
    <Compile Include="TuiReadOnlyTests.fs" />
    <Compile Include="HumanRenderSurfaceDriftTests.fs" />
    <!-- F27 wiring (063, US3/US4): the DISPATCHER's read-only watch/tui surfaces over a composed F19 view. -->
    <Compile Include="WatchTuiHostWiringTests.fs" />
    <!-- 090: the profile-aware handoff-gate decision matrix (strict/light/absent/unrecognized
         crossed with failing/satisfied at mode gate) driven through the public Cli MVU route-exit. -->
    <Compile Include="ProfileAwareHandoffGateTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Cli/FS.GG.Governance.Cli.fsproj" />
    <!-- F27: the HumanRender presentation library + the pure HumanText projection it renders, and
         the report cores needed to build a real ReportView fixture. -->
    <ProjectReference Include="../../src/FS.GG.Governance.HumanText/FS.GG.Governance.HumanText.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.HumanRender/FS.GG.Governance.HumanRender.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <!-- F27 wiring (063): reuse the RouteCommand test harness `withTempRepo`/`validCatalog` (a REAL temp
         git tree + real `.fsgg` catalog) so the dispatcher watch/tui wiring is proven through the SAME
         real compose path (Constitution V). Expecto scans only this entry assembly, so its tests do not
         double-run. The reference also brings RouteCommand for the compose call. -->
    <ProjectReference Include="../FS.GG.Governance.RouteCommand.Tests/FS.GG.Governance.RouteCommand.Tests.fsproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <!-- F028: the in-test GENERATOR + drift/completeness/coverage guards for the golden enforcement
       truth-table fixtures. A Tier-2 coverage/evidence deliverable: no new `src/` module, no `.fsi`,
       no surface baseline. The generator renders fixtures ONLY through the already-FSI-validated PUBLIC
       surfaces of the merged cores — F023 `Enforcement.deriveEffectiveSeverity`, F024 `Ship.rollup`,
       F025 `AuditJson.ofShipDecision`, F015 `Routing.route`, F017 `Findings.findUnknownGovernedPaths`,
       F014 `Config.Model` — never private helpers (Principle V). Every input is a real, literally-
       constructible typed value (the F025 `Support.fs` real-chain precedent); no mocks, no synthetic
       evidence. FsCheck is deliberately NOT referenced: the truth table is an EXHAUSTIVE enumeration of
       the closed dial cross-product, not a sampled property; determinism is asserted by regenerating
       twice and comparing. No new `PackageReference` (FR-011). -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="Generator.fs" />
    <Compile Include="TruthTableTests.fs" />
    <Compile Include="RouteClassTests.fs" />
    <Compile Include="AuditSnapshotTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Ship/FS.GG.Governance.Ship.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Route/FS.GG.Governance.Route.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.AuditJson/FS.GG.Governance.AuditJson.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Gates/FS.GG.Governance.Gates.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Findings/FS.GG.Governance.Findings.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Routing/FS.GG.Governance.Routing.fsproj" />
  </ItemGroup>

</Project>

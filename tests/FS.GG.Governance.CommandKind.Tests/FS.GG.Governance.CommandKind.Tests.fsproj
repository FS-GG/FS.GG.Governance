<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F25, exercising the PUBLIC surface of FS.GG.Governance.CommandKind:
       `Audit.kindToken`/`runIdentity`/`auditSnapshot`/`snapshotIdentity` and the `Model` types over REAL
       values (Principle V — the command-run fixtures are produced by the REAL F051 `Interpreter.realPort`
       driving real processes through `senseExecution`; the provenance inputs are real literal facts; no
       mock). Expecto gives the every-kind run fixtures, the duration-invariant identity, the snapshot
       byte-identity + stability + sentinel-exit fixtures, and the identity-reuse guard. The reflective
       SurfaceDrift test pins the Tier-1 public surface + the scope guard. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="RunIdentityTests.fs" />
    <Compile Include="AuditSnapshotTests.fs" />
    <Compile Include="IdentityReuseGuardTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.CommandKind/FS.GG.Governance.CommandKind.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.CommandRecord/FS.GG.Governance.CommandRecord.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Provenance/FS.GG.Governance.Provenance.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.GateExecution/FS.GG.Governance.GateExecution.fsproj" />
    <ProjectReference Include="../FS.GG.Governance.Tests.Common/FS.GG.Governance.Tests.Common.fsproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <!-- Semantic tests for F023, exercising the PUBLIC surface of FS.GG.Governance.Enforcement:
       `deriveEffectiveSeverity`, `recognizeMode`, `recognizeProfile`, `profileToProfileId`,
       `profileOfProfileId`, and `runModeOrdinal` over REAL typed lever values — the four lever DUs
       plus the reused F014 `Maturity`/`ProfileId` — never private helpers (the hidden
       `maturityFloor`/`profileTighten` maps and the four reason builders are tested ONLY through
       `deriveEffectiveSeverity`) and never mocks (Principle V). The entire input domain is the finite
       cross-product (2 × 5 × 6 × 4 = 240 inputs), all literally constructible, so NO synthetic
       evidence is anticipated. Expecto + FsCheck give the totality/determinism/carry/no-drop
       properties; the VSTest adapters let `dotnet test` drive the Expecto runner. -->
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Support.fs" />
    <Compile Include="DerivationTests.fs" />
    <Compile Include="RecognitionTests.fs" />
    <Compile Include="CarryTests.fs" />
    <Compile Include="DeterminismTests.fs" />
    <Compile Include="TotalityTests.fs" />
    <Compile Include="SurfaceDriftTests.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Expecto.FsCheck" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/FS.GG.Governance.Enforcement/FS.GG.Governance.Enforcement.fsproj" />
    <ProjectReference Include="../../src/FS.GG.Governance.Config/FS.GG.Governance.Config.fsproj" />
  </ItemGroup>

</Project>
